generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  passwordHash  String
  role          UserRole      @default(STAFF)
  otpCode       String?
  otpExpiresAt  DateTime?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  documents     Document[]
  ledgerEntries StockLedger[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Product {
  id            String         @id @default(cuid())
  name          String
  sku           String         @unique
  category      String
  brand         String?
  manufacturer  String?
  costPrice     Float?         @default(0)
  salePrice     Float?         @default(0)
  weight        Float?
  dimensions    String?
  unitOfMeasure String         @default("pcs")
  reorderLevel  Int            @default(10)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  documentLines DocumentLine[]
  ledgerEntries StockLedger[]
  stockQuants   StockQuant[]

  @@index([sku])
  @@index([category])
  @@index([name])
  @@index([brand])
  @@map("products")
}

model Warehouse {
  id        String     @id @default(cuid())
  name      String     @unique
  address   String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  locations Location[]

  @@map("warehouses")
}

model Location {
  id                    String         @id @default(cuid())
  name                  String
  type                  LocationType   @default(RACK)
  warehouseId           String
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  documentLinesAsDest   DocumentLine[] @relation("DestinationLocation")
  documentLinesAsSource DocumentLine[] @relation("SourceLocation")
  warehouse             Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  ledgerEntries         StockLedger[]
  stockQuants           StockQuant[]

  @@unique([warehouseId, name])
  @@index([warehouseId])
  @@index([type])
  @@map("locations")
}

model Document {
  id          String         @id @default(cuid())
  reference   String         @unique @default(cuid())
  type        DocumentType
  status      DocumentStatus @default(DRAFT)
  notes       String?
  supplier    String?
  customer    String?
  userId      String
  validatedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lines       DocumentLine[]
  user        User           @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@index([type, status])
  @@map("documents")
}

model DocumentLine {
  id               String    @id @default(cuid())
  documentId       String
  productId        String
  quantity         Float
  sourceLocationId String?
  destLocationId   String?
  destLocation     Location? @relation("DestinationLocation", fields: [destLocationId], references: [id])
  document         Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product          Product   @relation(fields: [productId], references: [id])
  sourceLocation   Location? @relation("SourceLocation", fields: [sourceLocationId], references: [id])

  @@index([documentId])
  @@index([productId])
  @@map("document_lines")
}

model StockQuant {
  id          String   @id @default(cuid())
  productId   String
  locationId  String
  quantity    Float    @default(0)
  reservedQty Float    @default(0)
  lastUpdated DateTime @updatedAt
  location    Location @relation(fields: [locationId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@unique([productId, locationId])
  @@index([productId])
  @@index([locationId])
  @@index([quantity])
  @@map("stock_quants")
}

model StockLedger {
  id           String         @id @default(cuid())
  productId    String
  locationId   String
  movement     LedgerMovement
  quantity     Float
  balanceAfter Float
  documentRef  String
  description  String?
  userId       String
  createdAt    DateTime       @default(now())
  location     Location       @relation(fields: [locationId], references: [id])
  product      Product        @relation(fields: [productId], references: [id])
  user         User           @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([locationId])
  @@index([userId])
  @@index([createdAt])
  @@index([movement])
  @@index([documentRef])
  @@index([productId, locationId, createdAt])
  @@map("stock_ledger")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum DocumentType {
  RECEIPT
  DELIVERY
  INTERNAL_TRANSFER
  ADJUSTMENT
}

enum DocumentStatus {
  DRAFT
  PICKING
  PACKING
  SHIPPED
  VALIDATED
  CANCELLED
}

enum LocationType {
  WAREHOUSE
  RACK
  BIN
  STAGING
}

enum LedgerMovement {
  IN
  OUT
}
